{
  "version": 2,
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/recommendations.js": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/flight-search.js": {
      "memory": 1024,
      "maxDuration": 90
    },
    "api/image-search.js": {
      "memory": 1024,
      "maxDuration": 90
    },
    "api/flight-results.js": {
      "memory": 1024,
      "maxDuration": 90
    },
    "api/flight-redirect.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/itinerary-generator.js": {
      "memory": 1024,
      "maxDuration": 180
    },
    "api/weather.js": {
      "memory": 1024,
      "maxDuration": 180
    },
    "api/cheapest-flights.js": {
      "memory": 1024,
      "maxDuration": 90
    },
    "api/search-destinations.js": {
      "memory": 1024,
      "maxDuration": 90
    },
    "api/multidatas.js": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/compare-flights.js": {
      "memory": 1024,
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/assets/js/:path*.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/assets/css/:path*.css",
      "headers": [
        { "key": "Content-Type", "value": "text/css; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
