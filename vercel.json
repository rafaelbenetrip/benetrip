{
  "version": 2,
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/recommendations.js": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/flight-search.js": {
      "memory": 1024,
      "maxDuration": 90
    },
    "api/image-search.js": {
      "memory": 1024,
      "maxDuration": 90
    },
    "api/flight-results.js": {
      "memory": 1024,
      "maxDuration": 90
    },
    "api/flight-redirect.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/itinerary-generator.js": {
      "memory": 1024,
      "maxDuration": 180
    },
    "api/weather.js": {
      "memory": 1024,
      "maxDuration": 180
    },
    "api/cheapest-flights.js": {
      "memory": 1024,
      "maxDuration": 90
    },
    "api/search-destinations.js": {
      "memory": 1024,
      "maxDuration": 90
    },
    "api/multidatas.js": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/compare-flights.js": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/discovery.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/cron/update-discovery.js": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/cron/instagram-post.js": {
      "memory": 1024,
      "maxDuration": 120
    },
    "api/instagram/generate-post.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/instagram/publish.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/instagram/card.js": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/destinos-baratos-page.js": {
      "memory": 1024,
      "maxDuration": 15
    },
    "api/escapadas-page.js": {
      "memory": 1024,
      "maxDuration": 15
    },
    "api/cron/update-escapadas.js": {
      "memory": 1024,
      "maxDuration": 300
    },
    "api/sitemap.js": {
      "memory": 1024,
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/destinos-baratos", "destination": "/api/destinos-baratos-page" },
    { "source": "/destinos-baratos/:cidade", "destination": "/api/destinos-baratos-page?cidade=:cidade" },
    { "source": "/escapadas", "destination": "/api/escapadas-page" },
    { "source": "/escapadas/:cidade", "destination": "/api/escapadas-page?cidade=:cidade" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" }
  ],
  "crons": [
    {
      "path": "/api/cron/update-discovery",
      "schedule": "0 6,18 * * *"
    },
    {
      "path": "/api/cron/update-escapadas",
      "schedule": "0 1,7,13,19 * * *"
    },
    {
      "path": "/api/cron/instagram-post",
      "schedule": "0 12 * * *"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/assets/js/:path*.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/assets/css/:path*.css",
      "headers": [
        { "key": "Content-Type", "value": "text/css; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
